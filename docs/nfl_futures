                if (aVal < bVal) return sortConfig.direction === 'asc' ? -1 : 1;
                if (aVal > bVal) return sortConfig.direction === 'asc' ? 1 : -1;
                return 0;
            });

            renderTable(currentData);
        }

        function filterData() {
            const searchTerm = searchInput.value.toLowerCase();
            const selectedDivision = divisionFilter.value;

            currentData = teamsData.filter(row => {
                const matchesSearch = row.team.toLowerCase().includes(searchTerm);
                const matchesDivision = !selectedDivision || row.division === selectedDivision;
                return matchesSearch && matchesDivision;
            });

            renderTable(currentData);
        }

        // Event listeners
        searchInput.addEventListener('input', filterData);
        divisionFilter.addEventListener('change', filterData);

        table.querySelectorAll('th.sortable').forEach((header, index) => {
            header.addEventListener('click', () => {
                const keyMap = [
                    'team', 'division', 'winTotal', 'makePlayoffs',
                    'winDivision', 'winConference', 'superBowl',
                    'overPrice', 'underPrice', 'overTrueOdds',
                    'underTrueOdds', 'edgeOver', 'edgeUnder'
                ];
                sortData(keyMap[index]);
            });
        });

        // Initial render
        renderTable(currentData);
    </script>
</body>
</html>
