                const tr = document.createElement('tr');
                const isPositiveEdgeOver = !row.edgeOver.startsWith('-');
                const isPositiveEdgeUnder = !row.edgeUnder.startsWith('-');

                tr.innerHTML = `
                    <td>${createTeamCell(row.team)}</td>
                    <td><span class="division-badge">${row.division}</span></td>
