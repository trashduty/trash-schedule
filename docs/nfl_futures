                sortConfig.direction = sortConfig.direction === 'asc' ? 'desc' : 'asc';
            } else {
                sortConfig.key = key;
                sortConfig.direction = 'asc';
            }

            const headers = table.querySelectorAll('th');
            headers.forEach(h => {
                h.classList.remove('sort-asc', 'sort-desc');
            });

            const keyMap = {
                'team': 0, 'division': 1, 'winTotal': 2, 'makePlayoffs': 3,
                'winDivision': 4, 'winConference': 5, 'superBowl': 6,
                'overPrice': 7, 'underPrice': 8, 'overTrueOdds': 9,
                'underTrueOdds': 10, 'edgeOver': 11, 'edgeUnder': 12
            };

            const sortHeader = Array.from(headers)[keyMap[key]];
            if (sortHeader) {
                sortHeader.classList.add(sortConfig.direction === 'asc' ? 'sort-asc' : 'sort-desc');
            }

            currentData.sort((a, b) => {
                let aVal = a[key];
                let bVal = b[key];

