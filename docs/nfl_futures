<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>NFL 2026 Season Win Totals</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }

        :root {
            --bg: #071016;
            --panel: #0d1a22;
            --panel-2: #101f29;
            --line: #233641;
            --text: #f3f7f8;
            --muted: #9eb0ba;
            --green: #5ce1a7;
            --green-dark: #1aa16f;
            --red: #ff7474;
            --gold: #f5c66a;
            --blue: #71b7ff;
            --shadow: 0 18px 55px rgba(0,0,0,.28);
        }

        html, body {
            height: 100%;
        }

        body {
            background:
                radial-gradient(circle at 12% -10%, rgba(92,225,167,.11), transparent 30%),
                radial-gradient(circle at 95% 5%, rgba(113,183,255,.08), transparent 26%),
                var(--bg);
            color: var(--text);
            font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
            font-size: 16px;
            line-height: 1.5;
            padding: 20px;
            min-height: 100vh;
        }

        .container {
            max-width: 1600px;
            margin: 0 auto;
        }

        header {
            margin-bottom: 32px;
        }

        .eyebrow {
            display: inline-flex;
            align-items: center;
            gap: 9px;
            color: var(--green);
            font-size: 0.78rem;
            font-weight: 800;
            letter-spacing: 0.13em;
            text-transform: uppercase;
            margin-bottom: 16px;
        }

        .eyebrow:before {
            content: "";
            width: 30px;
            height: 2px;
            background: var(--green);
        }

        h1 {
            font-size: clamp(2.2rem, 5vw, 3rem);
            font-weight: 800;
            line-height: 1.02;
            margin-bottom: 8px;
            letter-spacing: -0.055em;
            color: var(--text);
        }

        .subtitle {
            color: var(--muted);
            font-size: clamp(1rem, 1.8vw, 1.1rem);
            max-width: 700px;
        }

        .controls {
            display: flex;
            gap: 16px;
            margin-bottom: 24px;
            flex-wrap: wrap;
            align-items: center;
        }

        .search-box,
        .filter-select {
            background: var(--panel);
            border: 1px solid var(--line);
            color: var(--text);
            border-radius: 9px;
            padding: 12px 16px;
            font-family: inherit;
            font-size: 1rem;
            outline: none;
            transition: border-color 0.2s;
        }

        .search-box::placeholder,
        .filter-select {
            color: var(--muted);
        }

        .search-box:focus,
        .filter-select:focus {
            border-color: var(--green);
        }

        .search-box {
            min-width: 280px;
            flex: 1;
            min-width: 200px;
        }

        .filter-select {
            min-width: 180px;
        }

        .info-section {
            margin-bottom: 24px;
            padding: 16px;
            background: rgba(16,31,41,0.6);
            border: 1px solid var(--line);
            border-radius: 12px;
            color: var(--muted);
            font-size: 0.9rem;
        }

        .table-wrapper {
            background: linear-gradient(180deg, rgba(16,31,41,.96), rgba(11,24,32,.96));
            border: 1px solid var(--line);
            border-radius: 16px;
            box-shadow: var(--shadow);
            overflow: hidden;
            overflow-x: auto;
        }

        table {
            width: 100%;
            border-collapse: collapse;
            min-width: 1200px;
        }

        thead {
            background: rgba(0,0,0,0.3);
        }

        th {
            padding: 16px 12px;
            text-align: left;
            font-size: 0.73rem;
            font-weight: 700;
            text-transform: uppercase;
            letter-spacing: 0.075em;
            color: #91a5af;
            border-bottom: 1px solid var(--line);
            cursor: pointer;
            user-select: none;
            white-space: nowrap;
            background: rgba(0,0,0,0.2);
            transition: background 0.2s;
            position: relative;
        }

        th:hover {
            background: rgba(92,225,167,0.1);
        }

        th.sortable:after {
            content: " ⇅";
            opacity: 0.5;
            font-size: 0.9em;
            margin-left: 4px;
        }

        th.sort-asc:after {
            content: " ↑";
            opacity: 1;
            color: var(--green);
        }

        th.sort-desc:after {
            content: " ↓";
            opacity: 1;
            color: var(--green);
        }

        td {
            padding: 14px 12px;
            border-bottom: 1px solid var(--line);
            font-size: 0.9rem;
            color: var(--text);
        }

        tbody tr {
            transition: background-color 0.2s;
        }

        tbody tr:hover {
            background-color: rgba(92,225,167,0.05);
        }

        .team-cell {
            display: flex;
            align-items: center;
            gap: 12px;
            font-weight: 600;
            min-width: 220px;
        }

        .team-logo {
            width: 32px;
            height: 32px;
            border-radius: 4px;
            background-size: contain;
            background-repeat: no-repeat;
            background-position: center;
            flex-shrink: 0;
            font-size: 24px;
            display: flex;
            align-items: center;
            justify-content: center;
        }

        .team-name {
            flex: 1;
        }

        .division-badge {
            display: inline-block;
            background: rgba(113,183,255,0.15);
            color: var(--blue);
            padding: 4px 10px;
            border-radius: 999px;
            font-size: 0.78rem;
            font-weight: 700;
            border: 1px solid rgba(113,183,255,0.3);
            white-space: nowrap;
        }

        .percentage {
            font-variant-numeric: tabular-nums;
            font-weight: 600;
            text-align: center;
        }

        .price {
            font-variant-numeric: tabular-nums;
            font-weight: 600;
            color: var(--blue);
            text-align: center;
        }

        .positive {
            color: var(--green);
            font-weight: 700;
            text-align: center;
        }

        .negative {
            color: var(--red);
            font-weight: 700;
            text-align: center;
        }

        .edge-value {
            font-variant-numeric: tabular-nums;
            font-weight: 600;
            text-align: center;
        }

        .win-total {
            font-variant-numeric: tabular-nums;
            font-weight: 600;
            color: var(--gold);
            text-align: center;
        }

        .no-results {
            text-align: center;
            padding: 48px 24px;
            color: var(--muted);
            font-size: 1rem;
        }

        .result-count {
            padding: 12px 24px;
            color: var(--muted);
            font-size: 0.85rem;
            border-top: 1px solid var(--line);
            text-align: right;
        }

        @media (max-width: 768px) {
            .controls {
                flex-direction: column;
            }

            .search-box,
            .filter-select {
                width: 100%;
            }

            th, td {
                padding: 10px 8px;
                font-size: 0.8rem;
            }

            .team-cell {
                gap: 8px;
                min-width: 150px;
            }

            .team-logo {
                width: 28px;
                height: 28px;
            }

            h1 {
                font-size: 1.8rem;
            }

            .percentage,
            .price,
            .positive,
            .negative,
            .edge-value,
            .win-total {
                font-size: 0.85rem;
            }
        }
    </style>
</head>
